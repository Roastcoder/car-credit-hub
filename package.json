{
  "name": "mehar-finance",
  "version": "1.0.0",
  "description": "Mehar Finance Desktop Application",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "frontend:dev": "cd Frontend && npm run dev",
    "frontend:build": "cd Frontend && npm run build",
    "electron:dev": "electron .",
    "electron:build": "npm run frontend:build && electron-builder",
    "dev": "concurrently \"npm run frontend:dev\" \"wait-on http://localhost:3000 && npm run electron:dev\"",
    "build:win": "npm run frontend:build && electron-builder --win",
    "build:mac": "npm run frontend:build && electron-builder --mac"
  },
  "build": {
    "appId": "com.mehar.finance",
    "productName": "Mehar Finance",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "electron/**/*",
      "Frontend/dist/**/*"
    ],
    "icon": "electron/assets/icon.png",
    "win": {
      "target": "nsis",
      "icon": "electron/assets/icon.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "electron/assets/icon.png"
    }
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3",
    "concurrently": "^8.2.2",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "electron-serve": "^1.3.0"
  }
}
